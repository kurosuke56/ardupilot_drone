//////////////////////////////////////////////////
//
// Drone FC V1.1
//
// メインエントリーポイント
//
// 【役割】
// ・FlightController 初期化
// ・TelemetryServer 初期化
// ・共有データ初期化
// ・フライト制御タスク起動
// ・メインループ実行
//
// FreeRTOSを利用し、フライト制御を独立タスクとして
// 一定周期で実行する構成
//
//////////////////////////////////////////////////

#include "SharedData.h"

#include "FlightController.h"
#include "TelemetryServer.h"

//////////////////////////////////////////////////
// CONTROL SETTINGS
//////////////////////////////////////////////////

// フライト制御周期
//
// 4ms = 250Hz
//
// 一般的な小型ドローンでは
// 250Hz～1000Hz程度が多い
//
#define CONTROL_PERIOD_MS 4

//////////////////////////////////////////////////
// HARDWARE
//////////////////////////////////////////////////

// 動作状態表示LED
#define LED_PIN 21

  //////////////////////////////////////////////////
  // SHARED DATA
  //////////////////////////////////////////////////

  // ブラウザ → FCへ送られる操縦データ
  volatile RCCommand g_rc;

// FC → ブラウザへ送る状態データ
volatile TelemetryData g_tel;

//////////////////////////////////////////////////
// MODULE INSTANCE
//////////////////////////////////////////////////

// フライト制御クラス
FlightController fc;

// 通信管理クラス
TelemetryServer telemetry;

//////////////////////////////////////////////////
// FLIGHT TASK
//
// FreeRTOSタスク
//
// 一定周期でフライト制御を実行する
//
// loop()とは分離することで
// 通信負荷に影響されにくくする
//
//////////////////////////////////////////////////

void flightTask(
  void* pvParameters) {

  Serial.println(
    "FLIGHT START");

  // 周期制御用基準時間
  TickType_t lastWakeTime =
    xTaskGetTickCount();

  while (true) {

    //////////////////////////////////////////////////
    // フライト制御更新
    //////////////////////////////////////////////////

    fc.update();

    //////////////////////////////////////////////////
    // 周期固定
    //
    // vTaskDelayUntil() を使うことで
    // 処理時間が多少変動しても
    // 実行周期を一定に保つ
    //////////////////////////////////////////////////

    vTaskDelayUntil(
      &lastWakeTime,
      pdMS_TO_TICKS(
        CONTROL_PERIOD_MS));
  }
}

//////////////////////////////////////////////////
// SETUP
//
// 電源投入時に一度だけ実行
//////////////////////////////////////////////////

void setup() {

  //////////////////////////////////////////////////
  // シリアル初期化
  //////////////////////////////////////////////////

  Serial.begin(
    115200);

  delay(1000);

  Serial.println();

  Serial.println(
    "Drone FC V1.1");

  //////////////////////////////////////////////////
  // モジュール初期化
  //////////////////////////////////////////////////

  fc.begin();

  telemetry.begin();

  //////////////////////////////////////////////////
  // RC初期値
  //
  // 安全のためスロットル0
  // ARM解除状態で開始
  //////////////////////////////////////////////////

  g_rc.throttle = 0;
  g_rc.yaw = 0;
  g_rc.pitch = 0;
  g_rc.roll = 0;
  g_rc.armed = false;

  // 通信タイムスタンプ初期値
  g_rc.lastUpdateMs =
    millis();

  //////////////////////////////////////////////////
  // フライト制御タスク生成
  //////////////////////////////////////////////////

  xTaskCreatePinnedToCore(

    // 実行関数
    flightTask,

    // タスク名
    "FLIGHT",

    // スタックサイズ
    4096,

    // 引数
    NULL,

    // 優先度
    3,

    // タスクハンドル
    NULL,

    // 実行CPUコア
    1);

  Serial.println(
    "FLIGHT Task Created");

  Serial.println(
    "System Ready");

  //////////////////////////////////////////////////
  // LED初期化
  //////////////////////////////////////////////////

  pinMode(
    LED_PIN,
    OUTPUT);

  digitalWrite(
    LED_PIN,
    LOW);
}

//////////////////////////////////////////////////
// LOOP
//
// 通信処理専用
//
// フライト制御は別タスクで動くため
// loop()側ではWeb処理のみ行う
//
//////////////////////////////////////////////////

void loop() {

  telemetry.update();

  delay(2);
}

